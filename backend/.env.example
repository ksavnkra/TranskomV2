# Server Port
PORT=5000

# MongoDB Connection String
# Get yours from https://cloud.mongodb.com → Create Cluster → Connect → Drivers → Node.js
# Replace <username>, <password>, and <cluster> with your actual values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/transkom?retryWrites=true&w=majority

# JWT Secret Key — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# Google Gemini API Key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Email Notification (Gmail) — enable App Passwords: https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Exchange Rate API Key — get free key from https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here
